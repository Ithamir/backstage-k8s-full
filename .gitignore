# Ignore everything
*

# Allow folders
!**/

# Allow file types
!*.yaml
!*.tf
!*.hcl
!*.md
!*.tpl
!*.txt
!*.sh

# Allow specific files
!.gitignore
!Dockerfile
!.dockerignore
!Makefile

# Terraform state and cache (override folder allowlist)
terraform/.terraform/**
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/.terraform.tfstate.lock.info

# Explicitly Disallow
node_modules
.sandcastle
CLAUDE.md
