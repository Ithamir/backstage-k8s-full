# Ignore everything
*

# Allow folders
!**/

# Allow file types
!*.yaml
!*.yml
!*.tf
!*.hcl
!*.md
!*.tpl
!*.txt
!*.sh

# Allow specific files
!.gitignore
!Dockerfile
!.dockerignore
!hello-world/index.html

# Backstage app source (scaffolded, needed for build + yarn dev)
!backstage/.yarnrc.yml
!backstage/.yarn/releases/**
!backstage/.eslintignore
!backstage/.eslintrc.js
!backstage/.prettierignore
!backstage/backstage.json
!backstage/package.json
!backstage/yarn.lock
!backstage/tsconfig.json
!backstage/playwright.config.ts
!backstage/app-config.production.yaml
!backstage/rbac-policies.csv
!backstage/packages/**/*.ts
!backstage/packages/**/*.tsx
!backstage/packages/**/*.json
!backstage/packages/**/*.js
!backstage/packages/**/*.html
!backstage/packages/app/public/**

# Terraform state and cache (override folder allowlist)
terraform/.terraform/**
terraform/terraform.tfvars
!terraform/terraform.tfvars.example
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/.terraform.tfstate.lock.info
terraform/.generated/

# Helm dependency archives are rebuilt by Helm/ArgoCD from Chart.yaml.
charts/platform/*/charts/*.tgz

# Explicitly Disallow
node_modules
.sandcastle
CLAUDE.md
docs/agents

# Never track files prefixed with `secret-` (they typically hold real
# credentials produced by `kubectl create secret ... -o yaml`).
# Example templates that show the structure are explicitly allowed.
secret-*
!secret-*.example.*
